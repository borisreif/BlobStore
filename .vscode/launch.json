{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug blob demo",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/blob",
      "args": [
        "test_file.pdf",
        "out/report_copy.pdf"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "CMake: build",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
